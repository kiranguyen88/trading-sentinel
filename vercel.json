{
  "builds": [
    { "src": "app.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "crons": [
    { "path": "/cron/daily-digest",   "schedule": "0 11 * * 1-5"  },
    { "path": "/cron/close-summary",  "schedule": "5 20 * * 1-5"  },
    { "path": "/cron/watchlist-scan", "schedule": "55 10 * * 1-5" }
  ]
}
